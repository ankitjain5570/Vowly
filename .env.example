# Supabase connection for the /admin console.
# Copy this file to `.env` and fill in the two values from your Supabase
# project (Project Settings → API). Both are safe to expose in a frontend.
#
# 1. Create a free project at https://supabase.com
# 2. Run the SQL in supabase/schema.sql (SQL Editor → paste → Run)
# 3. Paste the two values below, then restart `npm run dev`
#
# Until these are set, the admin console runs on local browser storage
# (single-device preview, no real accounts). The guest site never needs them.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
